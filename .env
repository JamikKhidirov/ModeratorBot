# ─────────────────────────────────────────────
# 🤖 ModeratorBot — Конфигурация
# ─────────────────────────────────────────────
# 1. Получи токен бота у @BotFather в Telegram
# 2. Вставь его ниже вместо YOUR_BOT_TOKEN
# 3. Укажи свой Telegram ID (число) в ADMIN_IDS
#    Узнать свой ID: @userinfobot
# ─────────────────────────────────────────────

BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ID администраторов (через запятую, в квадратных скобках)
ADMIN_IDS=[123456789]

# База данных (по умолчанию SQLite)
DATABASE_URL=sqlite+aiosqlite:///database.sqlite3

# Пропускать старые апдейты при запуске
SKIP_UPDATES=True
